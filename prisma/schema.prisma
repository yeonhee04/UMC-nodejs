// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
 
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique(map: "email") @db.VarChar(255)
  password      String?   @db.VarChar(255) 
  name          String   @db.VarChar(100)
  gender        String   @db.VarChar(15)
  birth         DateTime @db.Date
  address       String   @db.VarChar(255)
  detailAddress String?  @map("detail_address") @db.VarChar(255)
  phoneNumber   String   @map("phone_number") @db.VarChar(15)
  userFavorCategories UserFavorCategory[]
  userStoreReviews    UserStoreReview[]  
  userMissions        UserMission[]        

  @@map("user")
}

model FoodCategory {
  id                  Int                 @id @default(autoincrement())
  name                String              @db.VarChar(100)
  userFavorCategories UserFavorCategory[]

  @@map("food_category")
}

model UserFavorCategory {
  id             Int          @id @default(autoincrement())
  user           User         @relation(fields: [userId], references: [id])
  userId         Int          @map("user_id")
  
  foodCategory   FoodCategory @relation(fields: [foodCategoryId], references: [id])
  foodCategoryId Int          @map("food_category_id")

  @@index([foodCategoryId], map: "f_category_id")
  @@index([userId], map: "user_id")
  @@map("user_favor_category")
}

model Store {
  id             Int               @id @default(autoincrement())
  
  regionId       Int               @map("region_id") @default(1)
  foodCategoryId Int               @map("food_category_id") @default(1)
  
  name           String            @db.VarChar(100)
  address        String            @db.VarChar(255) @default("주소 없음")

  userStoreReviews UserStoreReview[]
  missions         Mission[]        

  @@map("store")
}

model UserStoreReview {
  id       Int    @id @default(autoincrement())
  storeId  Int    @map("store_id")
  userId   Int    @map("user_id")
  score    Int    @default(5)
  content  String @db.Text

  store    Store  @relation(fields: [storeId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@map("user_store_review")
}

model Mission {
  id           Int            @id @default(autoincrement())
  storeId      Int            @map("store_id")
  reward       Int            @default(0)
  deadline     DateTime
  missionSpec  String         @map("mission_spec") @db.Text
  
  // 관계 설정
  store        Store          @relation(fields: [storeId], references: [id])
  userMissions UserMission[]

  @@map("mission")
}

model UserMission {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  missionId    Int      @map("mission_id")
  status       String   @default("진행중") @db.VarChar(15) // "진행중", "진행완료" 등
  
  // 관계 설정
  user         User     @relation(fields: [userId], references: [id])
  mission      Mission  @relation(fields: [missionId], references: [id])

  @@map("user_mission")
}